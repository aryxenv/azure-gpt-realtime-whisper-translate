# Azure OpenAI / Microsoft Foundry resource used by the realtime WebSocket proxy.
# Example: speech-ep-resource
AZURE_OPENAI_RESOURCE_NAME=

# Deployment name for your gpt-realtime-whisper deployment.
AZURE_OPENAI_REALTIME_DEPLOYMENT=gpt-realtime-whisper

# Optional: backend manual commit cadence for near-realtime transcript events.
# AZURE_OPENAI_REALTIME_COMMIT_INTERVAL_MS=1000
# AZURE_OPENAI_REALTIME_MIN_COMMIT_AUDIO_MS=250
# AZURE_OPENAI_REALTIME_MIN_AUDIO_RMS=0.01
# AZURE_OPENAI_REALTIME_STOP_DRAIN_MS=1200

# Authentication uses DefaultAzureCredential, not API keys.
# For local dev, run `az login` with an identity that can access the resource.
# For managed identity, assign the identity access to the resource.