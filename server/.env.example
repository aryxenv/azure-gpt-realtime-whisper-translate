# Azure OpenAI / Microsoft Foundry resource used by the realtime WebSocket proxy.
# Example: speech-ep-resource
AZURE_OPENAI_RESOURCE_NAME=

# Deployment name for your gpt-realtime-whisper deployment.
AZURE_OPENAI_REALTIME_DEPLOYMENT=gpt-realtime-whisper

# Optional: model names for the realtime translation slide.
# The browser slide selects the target output language before opening the websocket.
AZURE_OPENAI_REALTIME_TRANSLATION_MODEL=gpt-realtime-translate
AZURE_OPENAI_REALTIME_TRANSLATION_INPUT_TRANSCRIPTION_MODEL=gpt-realtime-whisper

# Optional: one ISO-639-1 language hint for controlled single-language tests.
# Leave unset for automatic language detection in multilingual rooms.
# AZURE_OPENAI_REALTIME_LANGUAGE_HINT=de

# Optional: try the gpt-realtime-whisper latency/accuracy knob if your Azure
# deployment supports it. Leave unset if Azure rejects the field.
# Supported values: minimal, low, medium, high, xhigh.
# AZURE_OPENAI_REALTIME_TRANSCRIPTION_DELAY=high

# Optional: backend Whisper commit strategy.
# none = endpoint-first default; append all audio and only finalize on stop.
# silence/fixed = fallback modes for manual local segmentation.
# AZURE_OPENAI_REALTIME_COMMIT_STRATEGY=none
# AZURE_OPENAI_REALTIME_COMMIT_INTERVAL_MS=2000
# AZURE_OPENAI_REALTIME_SILENCE_COMMIT_MS=900
# AZURE_OPENAI_REALTIME_MAX_COMMIT_AUDIO_MS=12000
# AZURE_OPENAI_REALTIME_MIN_COMMIT_AUDIO_MS=500
# AZURE_OPENAI_REALTIME_MIN_AUDIO_RMS=0.01
# AZURE_OPENAI_REALTIME_STOP_DRAIN_MS=2200

# Authentication uses DefaultAzureCredential, not API keys.
# For local dev, run `az login` with an identity that can access the resource.
# For managed identity, assign the identity access to the resource.